# Archivo de variables de entorno para el servicio systemd.
# Copiar a /etc/streaming.env y editar con los valores reales.
#
# sudo cp systemd/streaming.env.example /etc/streaming.env
# sudo nano /etc/streaming.env
# sudo chmod 600 /etc/streaming.env

# URL RTMP completa incluyendo el stream key
# YouTube Live:
RTMP_URL=rtmp://a.rtmp.youtube.com/live2/xxxx-xxxx-xxxx-xxxx

# Facebook Live:
# RTMP_URL=rtmps://live-api-s.facebook.com:443/rtmp/xxxx

# Servidor local:
# RTMP_URL=rtmp://192.168.1.100/live/cam

# Parámetros de video
STREAM_WIDTH=1920
STREAM_HEIGHT=1080
STREAM_FPS=30
STREAM_BITRATE=4500000

# Preset de re-encoding (solo aplica con overlays)
# ultrafast, superfast, veryfast, faster, fast
STREAM_PRESET=veryfast
