# Variables de entorno para analyze-server.py
# Copiar a /etc/ai-server.env y editar con los valores reales.
#
# sudo cp server/server.env.example /etc/ai-server.env
# sudo nano /etc/ai-server.env
# sudo chmod 600 /etc/ai-server.env

# Proveedor de IA: deepseek | openrouter
AI_PROVIDER=openrouter

# Modelo a usar (dejar vacío para usar el default del proveedor)
# DeepSeek:    deepseek-vl-7b-chat | deepseek-vl-67b-chat | deepseek-chat
# OpenRouter:  google/gemini-flash-1.5-8b | meta-llama/llama-3.2-11b-vision-instruct
AI_MODEL=google/gemini-flash-1.5-8b

# API Keys — definir solo la del proveedor que se va a usar
DEEPSEEK_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# Red
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
